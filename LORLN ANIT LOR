}

-- ============ Protection Functions ============
local function deleteNightVisionNow()
    pcall(function()
        local target = playerGui:FindFirstChild("HDAdminNightVision", true)
        if target then target:Destroy() end
    end)
    
    pcall(function()
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj.Name == "HDAdminNightVision" then
                obj:Destroy()
            end
        end
    end)
    
    pcall(function()
        for _, player in pairs(Players:GetPlayers()) do
            if player.Character then
                local target = player.Character:FindFirstChild("HDAdminNightVision", true)
                if target then target:Destroy() end
            end
        end
    end)
end

local function deleteAllElements()
    local currentTime = tick()
    
    if currentTime - lastDeleteTime < deleteInterval then
        return
    end
    
    lastDeleteTime = currentTime
    
    for _, name in ipairs(deleteTargets.PlayerGui) do
        pcall(function()
            local target = playerGui:FindFirstChild(name, true)
            if target then target:Destroy() end
        end)
    end
    
    for _, name in ipairs(deleteTargets.Workspace) do
        pcall(function()
            for _, obj in pairs(workspace:GetDescendants()) do
                if obj.Name == name then
                    obj:Destroy()
                end
            end
        end)
    end
    
    for _, name in ipairs(deleteTargets.Characters) do
        pcall(function()
            for _, player in pairs(Players:GetPlayers()) do
                if player.Character then
                    local target = player.Character:FindFirstChild(name, true)
                    if target then target:Destroy() end
                end
            end
        end)
    end
end

local function toggleNightVision(state)
    pcall(function()
        local nightVision = ReplicatedStorage:FindFirstChild("HDAdminHDClient", true)
        if nightVision then
            local assets = nightVision:FindFirstChild("Assets", true)
            if assets then
                local nv = assets:FindFirstChild("NightVision") or assets:FindFirstChild("1NightVision")
                if nv then
                    nv.Name = state == "start" and "1NightVision" or "NightVision"
                end
            end
        end
    end)
end

local function toggleTemplate(state)
    pcall(function()
        local hdInterface = playerGui:FindFirstChild("HDAdminInterface", true)
        if hdInterface then
            local templates = hdInterface:FindFirstChild("MenuTemplates", true)
            if templates then
                local template = templates:FindFirstChild("Template5") or templates:FindFirstChild("Template")
                if template then
                    template.Name = state == "start" and "Template" or "Template5"
                end
            end
        end
    end)
end

-- ============ Start/Stop Protection ============
local function startProtection()
    protectionActive = true
    
    ProtectButton.Text = "STOP PROTECTION"
    ProtectButton.BackgroundColor3 = THEME.Error
    ButtonStroke.Color = THEME.Error
    ButtonStroke.Transparency = 0
    
    StatusDot.BackgroundColor3 = THEME.Success
    StatusText.Text = "ACTIVE"
    StatusText.TextColor3 = THEME.Success
    
    toggleNightVision("start")
    toggleTemplate("start")
    deleteNightVisionNow()
end

local function stopProtection()
    protectionActive = false
    
    ProtectButton.Text = "START PROTECTION"
    ProtectButton.BackgroundColor3 = THEME.AccentDark
    ButtonStroke.Color = THEME.Accent
    ButtonStroke.Transparency = 0.3
    
    StatusDot.BackgroundColor3 = THEME.Error
    StatusText.Text = "INACTIVE"
    StatusText.TextColor3 = THEME.DarkText
    
    toggleNightVision("stop")
    toggleTemplate("stop")
end

