local protectionActive = false
local lastDeleteTime = 0
local deleteInterval = 20

-- Delete targets list
local deleteTargets = {
    PlayerGui = {
        "CommandMenucommandLogs",
        "CommandMenuchatLogs", 
        "CustomTopBar",
        "HDAdminNightVision"
    },
    Workspace = {
        "HDAdminNightVision"
